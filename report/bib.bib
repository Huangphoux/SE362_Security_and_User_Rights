	urldate = {2026-04-19},
}


@misc{proof,
	title = {Why does {Anubis} use {Proof}-of-{Work}? {\textbar} {Anubis}},
	shorttitle = {Why does {Anubis} use {Proof}-of-{Work}?},
	url = {https://anubis.techaro.lol/docs/design/why-proof-of-work},
	abstract = {Anubis uses proof of work in order to validate that clients are genuine. The reason Anubis does this was inspired by Hashcash, a suggestion from the early 2000's about extending the email protocol to avoid spam. The idea is that genuine people sending emails will have to do a small math problem that is expensive to compute, but easy to verify such as hashing a string with a given number of leading zeroes. This will have basically no impact on individuals sending a few emails a week, but the company churning out industrial quantities of advertising will be required to do prohibitively expensive computation. This is also how Bitcoin's consensus algorithm works.},
	language = {en},
	urldate = {2026-04-19},
}


